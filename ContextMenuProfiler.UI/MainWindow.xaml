<ui:FluentWindow x:Class="ContextMenuProfiler.UI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:ContextMenuProfiler.UI"
        xmlns:viewmodels="clr-namespace:ContextMenuProfiler.UI.ViewModels"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        xmlns:services="clr-namespace:ContextMenuProfiler.UI.Core.Services"
        mc:Ignorable="d"
        Title="{Binding ApplicationTitle}" Height="750" Width="1100"
        WindowStartupLocation="CenterScreen"
        ExtendsContentIntoTitleBar="True"
        WindowBackdropType="Mica"
        AllowDrop="True" Drop="Window_Drop" DragOver="Window_DragOver"
        d:DataContext="{d:DesignInstance viewmodels:MainWindowViewModel}">

    <Grid AllowDrop="True" Drop="Window_Drop" DragOver="Window_DragOver" Background="Transparent">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <ui:NavigationView
            x:Name="RootNavigation"
            Grid.Row="0"
            Padding="0"
            FrameMargin="0"
            IsBackButtonVisible="Visible"
            IsPaneToggleVisible="True"
            MenuItemsSource="{Binding MenuItems}"
            FooterMenuItemsSource="{Binding FooterMenuItems}"
            PaneDisplayMode="Left"
            TitleBar="{Binding ElementName=TitleBar, Mode=OneWay}"
            AllowDrop="True" Drop="Window_Drop" DragOver="Window_DragOver">
            
            <ui:NavigationView.Header>
                 <ui:BreadcrumbBar x:Name="BreadcrumbBar" Margin="42,32,42,20" />
            </ui:NavigationView.Header>

        </ui:NavigationView>

        <!-- Status Bar -->
        <Border Grid.Row="1" Height="28" Background="{DynamicResource SystemControlBackgroundAltHighBrush}" BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}" BorderThickness="0,1,0,0">
            <Grid Margin="12,0">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Left">
                    <ui:SymbolIcon Symbol="Info24" FontSize="12" Margin="0,0,8,0" Opacity="0.6" VerticalAlignment="Center"/>
                    <TextBlock Text="{Binding StatusBarVersionText}" VerticalAlignment="Center" FontSize="11" Opacity="0.6"/>
                </StackPanel>

                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <Rectangle Width="1" Fill="{DynamicResource ControlStrokeColorDefaultBrush}" Margin="8,4" SnapsToDevicePixels="True"/>
                    
                    <ui:Button Appearance="Transparent" 
                               Padding="12,0" 
                               Height="28"
                               BorderThickness="0"
                               BorderBrush="Transparent"
                               Command="{Binding ToggleHookCommand}" 
                               ToolTip="{Binding HookButtonText}">
                        <StackPanel Orientation="Horizontal">
                            <ui:SymbolIcon Symbol="Shield24" Margin="0,0,8,0" FontSize="14" VerticalAlignment="Center">
                                <ui:SymbolIcon.Style>
                                    <Style TargetType="ui:SymbolIcon">
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding CurrentHookStatus}" Value="{x:Static services:HookStatus.Active}">
                                                <Setter Property="Foreground" Value="#4CAF50"/>
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding CurrentHookStatus}" Value="{x:Static services:HookStatus.Injected}">
                                                <Setter Property="Foreground" Value="#FFC107"/>
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding CurrentHookStatus}" Value="{x:Static services:HookStatus.Disconnected}">
                                                <Setter Property="Foreground" Value="#F44336"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </ui:SymbolIcon.Style>
                            </ui:SymbolIcon>
                            <TextBlock Text="{Binding HookStatusMessage}" VerticalAlignment="Center" FontSize="11" Opacity="0.8"/>
                        </StackPanel>
                    </ui:Button>
                </StackPanel>
            </Grid>
        </Border>

        <ui:TitleBar
            x:Name="TitleBar"
            Title="{Binding ApplicationTitle}"
            Grid.Row="0"
            CloseWindowByDoubleClickOnIcon="True">
            <ui:TitleBar.Icon>
                <ui:SymbolIcon Symbol="AppGeneric24" />
            </ui:TitleBar.Icon>
        </ui:TitleBar>

        <ui:SnackbarPresenter x:Name="RootSnackbar" Grid.Row="0"/>
    </Grid>
</ui:FluentWindow>
