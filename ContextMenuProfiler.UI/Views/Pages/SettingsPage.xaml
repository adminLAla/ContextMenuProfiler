<Page x:Class="ContextMenuProfiler.UI.Views.Pages.SettingsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
      xmlns:viewmodels="clr-namespace:ContextMenuProfiler.UI.ViewModels"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="Settings"
      d:DataContext="{d:DesignInstance viewmodels:SettingsViewModel}">
    
    <Grid Margin="66,24,66,24">
        <StackPanel>
            <ui:TextBlock Text="System Tools" FontTypography="Subtitle" Margin="0,0,0,12"/>
            
            <ui:Card Padding="16">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <ui:SymbolIcon Grid.Column="0" Symbol="ArrowReset24" Margin="0,2,14,0" VerticalAlignment="Top"/>

                    <StackPanel Grid.Column="1" Margin="0,0,16,0">
                        <TextBlock Text="Restart Explorer" FontWeight="SemiBold" FontSize="14"/>
                        <TextBlock Text="Restarts Windows Explorer process. Useful when shell extensions are stuck or not loading."
                                   TextWrapping="Wrap"
                                   Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                   FontSize="12"
                                   Margin="0,2,0,0"/>
                    </StackPanel>

                    <ui:Button Grid.Column="2"
                               VerticalAlignment="Top"
                               MinWidth="96"
                               Content="Restart"
                               Icon="{ui:SymbolIcon Symbol=ArrowReset24}"
                               Command="{Binding RestartExplorerCommand}"/>
                </Grid>
            </ui:Card>
        </StackPanel>
    </Grid>
</Page>
