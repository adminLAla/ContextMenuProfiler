<Page x:Class="ContextMenuProfiler.UI.Views.Pages.SettingsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
      xmlns:viewmodels="clr-namespace:ContextMenuProfiler.UI.ViewModels"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="Settings"
      d:DataContext="{d:DesignInstance viewmodels:SettingsViewModel}">
    
    <Grid Margin="66,24,66,24">
        <StackPanel>
            <ui:TextBlock Text="System Tools" FontTypography="Subtitle" Margin="0,0,0,12"/>
            
            <ui:CardControl>
                <ui:CardControl.Icon>
                    <ui:SymbolIcon Symbol="ArrowReset24"/>
                </ui:CardControl.Icon>
                <ui:CardControl.Header>
                    <StackPanel>
                        <TextBlock Text="Restart Explorer" FontWeight="SemiBold" FontSize="14"/>
                        <TextBlock Text="Restarts Windows Explorer process. Useful when shell extensions are stuck or not loading." 
                                   Foreground="{DynamicResource TextFillColorSecondaryBrush}" FontSize="12" Margin="0,2,0,0"/>
                    </StackPanel>
                </ui:CardControl.Header>
                <ui:Button Content="Restart" Icon="{ui:SymbolIcon Symbol=ArrowReset24}" Command="{Binding RestartExplorerCommand}"/>
            </ui:CardControl>
        </StackPanel>
    </Grid>
</Page>