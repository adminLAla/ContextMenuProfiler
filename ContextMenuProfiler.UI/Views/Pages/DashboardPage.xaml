<Page x:Class="ContextMenuProfiler.UI.Views.Pages.DashboardPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
      xmlns:pages="clr-namespace:ContextMenuProfiler.UI.Views.Pages"
      xmlns:viewmodels="clr-namespace:ContextMenuProfiler.UI.ViewModels"
      xmlns:converters="clr-namespace:ContextMenuProfiler.UI.Converters"
      xmlns:services="clr-namespace:ContextMenuProfiler.UI.Core.Services"
      xmlns:helpers="clr-namespace:ContextMenuProfiler.UI.Core.Helpers"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="Dashboard"
    d:DataContext="{d:DesignInstance viewmodels:DashboardViewModel}"
    AllowDrop="True" Drop="Page_Drop" DragOver="Page_DragOver"
    Background="Transparent"
    helpers:SmoothScrollingHelper.IsSmoothScrollingEnabled="True">

    <Page.Resources>
        <converters:TypeToIconConverter x:Key="TypeToIconConverter"/>
        <converters:StatusToVisibilityConverter x:Key="StatusToVisibilityConverter"/>
        <converters:IconToImageConverter x:Key="IconToImageConverter"/>
        <converters:StringNullOrEmptyToVisibilityConverter x:Key="StringNullOrEmptyToVisibilityConverter"/>
        <converters:LoadTimeToBrushConverter x:Key="LoadTimeToBrushConverter"/>
        <converters:LoadTimeToTextConverter x:Key="LoadTimeToTextConverter"/>
        <converters:NullOrEmptyToLocalizedConverter x:Key="NullOrEmptyToLocalizedConverter"/>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>
    </Page.Resources>

    <Grid Margin="32,24,32,24" Background="Transparent" AllowDrop="True" Drop="Page_Drop" DragOver="Page_DragOver">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Stats Cards -->
        <Grid Grid.Row="0" Margin="0,0,0,24">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Hook Warning Banner -->
            <Border Grid.Row="0"
                    Margin="0,0,0,16"
                    Visibility="{Binding CurrentHookStatus, Converter={StaticResource StatusToVisibilityConverter}, ConverterParameter=NotActive}"
                    Padding="16,14,16,10"
                    BorderThickness="1"
                    CornerRadius="{DynamicResource ControlCornerRadius}"
                    BorderBrush="{DynamicResource InfoBarBorderBrush}"
                    Background="{DynamicResource InfoBarWarningSeverityBackgroundBrush}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <ui:SymbolIcon Grid.Column="0"
                                   Filled="True"
                                   Symbol="ErrorCircle24"
                                   Margin="0,2,14,0"
                                   VerticalAlignment="Top"
                                   Foreground="{DynamicResource InfoBarWarningSeverityIconBackground}"/>

                    <StackPanel Grid.Column="1" Margin="0,0,12,0">
                        <TextBlock Text="{Binding HookStatusMessage}" FontWeight="SemiBold" TextWrapping="Wrap"/>
                        <TextBlock Text="{Binding [Dashboard.HookWarning], Source={x:Static services:LocalizationService.Instance}}"
                                   TextWrapping="Wrap"/>
                    </StackPanel>

                    <ui:Button Grid.Column="2"
                               VerticalAlignment="Top"
                               Content="{Binding [Dashboard.ReconnectInject], Source={x:Static services:LocalizationService.Instance}}"
                               Command="{Binding ReconnectHookCommand}" />
                </Grid>
            </Border>

            <Grid Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <ui:Card Grid.Column="0" Margin="0,0,8,0" Padding="16">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                            <ui:SymbolIcon Symbol="AppsList24" FontSize="20" Margin="0,0,8,0" Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                            <TextBlock Text="{Binding [Dashboard.TotalExtensions], Source={x:Static services:LocalizationService.Instance}}" FontWeight="SemiBold" Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                        </StackPanel>
                        <TextBlock Text="{Binding TotalExtensions}" FontSize="28" FontWeight="Bold"/>
                        <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                            <ui:SymbolIcon Symbol="Timer24" FontSize="14" Margin="0,1,4,0" Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                            <TextBlock Text="{Binding TotalLoadTime, StringFormat='{}{0} ms'}" Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                        </StackPanel>
                    </StackPanel>
                </ui:Card>

                <ui:Card Grid.Column="1" Margin="4,0,4,0" Padding="16">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                            <ui:SymbolIcon Symbol="CheckmarkCircle24" FontSize="20" Margin="0,0,8,0" Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                            <TextBlock Text="{Binding [Dashboard.Active], Source={x:Static services:LocalizationService.Instance}}" FontWeight="SemiBold" Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                        </StackPanel>
                        <TextBlock Text="{Binding ActiveExtensions}" FontSize="28" FontWeight="Bold"/>
                        <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                            <ui:SymbolIcon Symbol="Timer24" FontSize="14" Margin="0,1,4,0" Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                            <TextBlock Text="{Binding ActiveLoadTime, StringFormat='{}{0} ms'}" Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                        </StackPanel>
                    </StackPanel>
                </ui:Card>

                <ui:Card Grid.Column="2" Margin="8,0,0,0" Padding="16">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                            <ui:SymbolIcon Symbol="Timer24" FontSize="20" Margin="0,0,8,0" Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                            <TextBlock Text="{Binding [Dashboard.RealWorldLoad], Source={x:Static services:LocalizationService.Instance}}" FontWeight="SemiBold" Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                        </StackPanel>
                        <TextBlock Text="{Binding RealLoadTime}" FontSize="28" FontWeight="Bold"/>
                        <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                            <ui:SymbolIcon Symbol="Info24" FontSize="14" Margin="0,1,4,0" Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                            <TextBlock Text="{Binding [Dashboard.TotalMenuTime], Source={x:Static services:LocalizationService.Instance}}" Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                        </StackPanel>
                    </StackPanel>
                </ui:Card>
            </Grid>
        </Grid>

        <!-- Actions -->
        <Grid Grid.Row="1" Margin="0,0,0,16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0" Orientation="Horizontal">
                <ui:Button Content="{Binding [Dashboard.ScanSystem], Source={x:Static services:LocalizationService.Instance}}" Icon="{ui:SymbolIcon Symbol=Search24}" Appearance="Primary" Command="{Binding ScanSystemCommand}" Margin="0,0,8,0"/>
                <ui:Button Content="{Binding [Dashboard.AnalyzeFile], Source={x:Static services:LocalizationService.Instance}}" Icon="{ui:SymbolIcon Symbol=DocumentSearch24}" Appearance="Secondary" Command="{Binding PickAndScanFileCommand}" Margin="0,0,8,0"/>
                
                <Rectangle Width="1" Fill="{DynamicResource ControlStrokeColorDefaultBrush}" Margin="8,4" SnapsToDevicePixels="True"/>

                <ui:Button Appearance="Secondary" Command="{Binding RefreshCommand}" ToolTip="{Binding [Dashboard.Refresh], Source={x:Static services:LocalizationService.Instance}}" Margin="8,0,0,0" VerticalAlignment="Stretch">
                     <ui:Button.Icon>
                        <ui:SymbolIcon Symbol="ArrowClockwise24">
                            <ui:SymbolIcon.Style>
                                <Style TargetType="ui:SymbolIcon">
                                    <Style.Triggers>
                                <DataTrigger Binding="{Binding IsBusy}" Value="True">
                                    <DataTrigger.EnterActions>
                                        <BeginStoryboard>
                                            <Storyboard>
                                                <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(RotateTransform.Angle)" From="0" To="360" Duration="0:0:1" RepeatBehavior="Forever"/>
                                            </Storyboard>
                                        </BeginStoryboard>
                                    </DataTrigger.EnterActions>
                                    <DataTrigger.ExitActions>
                                        <BeginStoryboard>
                                            <Storyboard>
                                                <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(RotateTransform.Angle)" To="0" Duration="0:0:0"/>
                                            </Storyboard>
                                        </BeginStoryboard>
                                    </DataTrigger.ExitActions>
                                </DataTrigger>
                            </Style.Triggers>
                                    <Setter Property="RenderTransformOrigin" Value="0.5,0.5"/>
                                    <Setter Property="RenderTransform">
                                        <Setter.Value>
                                            <RotateTransform Angle="0"/>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                            </ui:SymbolIcon.Style>
                        </ui:SymbolIcon>
                     </ui:Button.Icon>
                </ui:Button>
            </StackPanel>
            
            <TextBlock Grid.Column="1" Text="{Binding StatusText}" VerticalAlignment="Center" Margin="16,0" Foreground="{DynamicResource TextFillColorSecondaryBrush}" TextTrimming="CharacterEllipsis"/>
            
            <ui:ToggleSwitch Grid.Column="2" IsChecked="{Binding UseDeepScan}" Content="{Binding [Dashboard.DeepScan], Source={x:Static services:LocalizationService.Instance}}" ToolTip="{Binding [Dashboard.DeepScanTip], Source={x:Static services:LocalizationService.Instance}}" VerticalAlignment="Center"/>
        </Grid>

        <!-- Toolbar (Search & Sort) -->
        <Grid Grid.Row="2" Margin="0,0,0,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <ui:TextBox PlaceholderText="{Binding [Dashboard.SearchExtensions], Source={x:Static services:LocalizationService.Instance}}" Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                        Icon="{ui:SymbolIcon Symbol=Search24}" Margin="0,0,12,0"/>

            <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                <ui:ToggleSwitch Margin="0,0,12,0"
                                 IsChecked="{Binding ShowMeasuredOnly}"
                                 Content="{Binding [Dashboard.FilterMeasuredOnly], Source={x:Static services:LocalizationService.Instance}}"
                                 ToolTip="{Binding [Dashboard.FilterMeasuredOnlyTip], Source={x:Static services:LocalizationService.Instance}}"/>

                <ComboBox SelectedIndex="{Binding SelectedSortIndex}" MinWidth="200" VerticalAlignment="Center">
                    <ComboBoxItem Content="{Binding [Dashboard.Sort.LoadDesc], Source={x:Static services:LocalizationService.Instance}}"/>
                    <ComboBoxItem Content="{Binding [Dashboard.Sort.LoadAsc], Source={x:Static services:LocalizationService.Instance}}"/>
                    <ComboBoxItem Content="{Binding [Dashboard.Sort.NameAsc], Source={x:Static services:LocalizationService.Instance}}"/>
                    <ComboBoxItem Content="{Binding [Dashboard.Sort.Latest], Source={x:Static services:LocalizationService.Instance}}"/>
                </ComboBox>
            </StackPanel>
        </Grid>

        <!-- Category Selection (ListBox styled as Pivot/Segmented with adaptive layout) -->
        <ListBox Grid.Row="3" Margin="0,0,0,16" 
                 x:Name="CategoryListBox"
                 ItemsSource="{Binding Categories}"
                 SelectedIndex="{Binding SelectedCategoryIndex, Mode=TwoWay}"
                 Background="Transparent" BorderThickness="0"
                 ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                 ScrollViewer.VerticalScrollBarVisibility="Disabled">
            <ListBox.ItemsPanel>
                <ItemsPanelTemplate>
                    <StackPanel Orientation="Horizontal"/>
                </ItemsPanelTemplate>
            </ListBox.ItemsPanel>
            <ListBox.ItemContainerStyle>
                <Style TargetType="ListBoxItem">
                    <Setter Property="Background" Value="Transparent"/>
                    <Setter Property="BorderThickness" Value="0"/>
                    <Setter Property="Padding" Value="12,8"/>
                    <Setter Property="Margin" Value="0,0,4,0"/>
                    <Setter Property="Cursor" Value="Hand"/>
                    <Setter Property="ToolTip" Value="{Binding Name}"/>
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="ListBoxItem">
                                <Grid Background="Transparent">
                                    <Border x:Name="SelectionIndicator" 
                                            Height="3" VerticalAlignment="Bottom"
                                            Background="{DynamicResource SystemAccentColorPrimaryBrush}"
                                            CornerRadius="1.5" Margin="8,0,8,0"
                                            Opacity="0"/>
                                    
                                    <ContentPresenter Margin="{TemplateBinding Padding}" 
                                                      HorizontalAlignment="Center" 
                                                      VerticalAlignment="Center"/>
                                    
                                    <VisualStateManager.VisualStateGroups>
                                        <VisualStateGroup x:Name="SelectionStates">
                                            <VisualState x:Name="Unselected"/>
                                            <VisualState x:Name="Selected">
                                                <Storyboard>
                                                    <DoubleAnimation Storyboard.TargetName="SelectionIndicator" 
                                                                     Storyboard.TargetProperty="Opacity" 
                                                                     To="1" Duration="0:0:0.2"/>
                                                </Storyboard>
                                            </VisualState>
                                        </VisualStateGroup>
                                    </VisualStateManager.VisualStateGroups>
                                </Grid>
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                </Style>
            </ListBox.ItemContainerStyle>
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <ui:SymbolIcon Symbol="{Binding Icon}" FontSize="20" 
                                       Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                        <TextBlock x:Name="CategoryNameText" Text="{Binding Name}" FontSize="14" FontWeight="Medium" 
                                   Margin="8,0,0,0" VerticalAlignment="Center"/>
                    </StackPanel>
                    <DataTemplate.Triggers>
                        <DataTrigger Binding="{Binding ActualWidth, RelativeSource={RelativeSource AncestorType=Page}, Converter={StaticResource LoadTimeToBrushConverter}, ConverterParameter=AdaptiveMode}" Value="True">
                            <Setter TargetName="CategoryNameText" Property="Visibility" Value="Collapsed"/>
                        </DataTrigger>
                    </DataTemplate.Triggers>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>

        <!-- List View (Modern Expander Style) -->
        <!-- Fixed Height / Vertical Alignment ensure Virtualization is NOT killed by parent containers -->
        <ui:ListView Grid.Row="4" ItemsSource="{Binding DisplayResults}" SelectionMode="Single" 
                     ScrollViewer.HorizontalScrollBarVisibility="Disabled" 
                     ScrollViewer.VerticalScrollBarVisibility="Auto"
                     ScrollViewer.CanContentScroll="True"
                     VerticalAlignment="Stretch"
                     VirtualizingPanel.IsVirtualizing="True"
                     VirtualizingPanel.VirtualizationMode="Recycling"
                     VirtualizingPanel.CacheLengthUnit="Item"
                     VirtualizingPanel.CacheLength="5,5"
                     VirtualizingPanel.ScrollUnit="Pixel"
                     AllowDrop="True" Drop="Page_Drop" DragOver="Page_DragOver">
                    <ui:ListView.ItemContainerStyle>
                <Style TargetType="{x:Type ui:ListViewItem}" BasedOn="{StaticResource {x:Type ui:ListViewItem}}">
                    <Setter Property="Padding" Value="0"/>
                    <Setter Property="Margin" Value="0,0,0,8"/>
                    <Setter Property="BorderThickness" Value="0"/>
                    <Setter Property="Background" Value="Transparent"/>
                    <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                    <Style.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                             <Setter Property="Background" Value="Transparent"/>
                        </Trigger>
                    </Style.Triggers>
                </Style>
            </ui:ListView.ItemContainerStyle>
            <ui:ListView.ItemTemplate>
                <DataTemplate>
                    <ui:Card Padding="0" Margin="0">
                        <Expander Padding="16" HorizontalContentAlignment="Stretch">
                            <Expander.Header>
                                <Grid HorizontalAlignment="Stretch">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/> <!-- Icon -->
                                        <ColumnDefinition Width="*"/>    <!-- Info -->
                                        <ColumnDefinition Width="Auto"/> <!-- Time -->
                                        <ColumnDefinition Width="Auto"/> <!-- Toggle -->
                                        <ColumnDefinition Width="Auto"/> <!-- Spacer for expander arrow -->
                                    </Grid.ColumnDefinitions>

                                    <!-- Icon -->
                                    <Grid Grid.Column="0" Width="32" Height="32" Margin="0,0,16,0" VerticalAlignment="Center">
                                        <Viewbox Visibility="{Binding IconLocation, Converter={StaticResource StringNullOrEmptyToVisibilityConverter}}">
                                            <ui:SymbolIcon Symbol="{Binding Type, Converter={StaticResource TypeToIconConverter}}" FontSize="24"/>
                                        </Viewbox>
                                        <Image Source="{Binding IconLocation, Converter={StaticResource IconToImageConverter}}" Stretch="Uniform"
                                               Visibility="{Binding IconLocation, Converter={StaticResource StringNullOrEmptyToVisibilityConverter}, ConverterParameter=Inverse}"/>
                                    </Grid>

                                    <!-- Main Info -->
                                    <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="0,0,16,0">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="{Binding Name}" FontWeight="SemiBold" FontSize="14" TextTrimming="CharacterEllipsis"/>
                                            <ui:SymbolIcon Symbol="Warning24" FontSize="16" Margin="8,0,0,0" VerticalAlignment="Center"
                                                        ToolTip="{Binding DetailedStatus}">
                                                <ui:SymbolIcon.Style>
                                                    <Style TargetType="ui:SymbolIcon">
                                                        <Setter Property="Foreground" Value="#FFC107"/> <!-- Default Yellow for Warnings -->
                                                        <Setter Property="Visibility" Value="{Binding Status, Converter={StaticResource StatusToVisibilityConverter}}"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding Status}" Value="Registry Fallback">
                                                                <Setter Property="Foreground" Value="#FFC107"/> <!-- Yellow for global Hook failure -->
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding Status}" Value="Hook Loaded (No Menu)">
                                                                <Setter Property="Foreground" Value="#FFC107"/> <!-- Yellow for empty menu -->
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding Status}" Value="Load Error">
                                                                <Setter Property="Foreground" Value="{DynamicResource SystemFillColorCriticalBrush}"/>
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding Status}" Value="Orphaned / Missing DLL">
                                                                <Setter Property="Foreground" Value="{DynamicResource SystemFillColorCriticalBrush}"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </ui:SymbolIcon.Style>
                                            </ui:SymbolIcon>
                                        </StackPanel>
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="{Binding Type}" FontSize="11" Foreground="{DynamicResource TextFillColorSecondaryBrush}" Opacity="0.7"/>
                                            <TextBlock Text=" • " FontSize="11" Foreground="{DynamicResource TextFillColorSecondaryBrush}" Opacity="0.5"
                                                       Visibility="{Binding LocationSummary, Converter={StaticResource StringNullOrEmptyToVisibilityConverter}, ConverterParameter=Inverse}"/>
                                            <TextBlock Text="{Binding LocationSummary}" FontSize="11" Foreground="{DynamicResource TextFillColorSecondaryBrush}" Opacity="0.7"
                                                       Visibility="{Binding LocationSummary, Converter={StaticResource StringNullOrEmptyToVisibilityConverter}, ConverterParameter=Inverse}"/>
                                        </StackPanel>
                                    </StackPanel>

                                    <!-- Performance Badge -->
                                    <Border Grid.Column="2" VerticalAlignment="Center" Margin="0,0,16,0" Padding="6,2" CornerRadius="4" 
                                            Background="{Binding TotalTime, Converter={StaticResource LoadTimeToBrushConverter}, ConverterParameter=Background}">
                                        <Border.ToolTip>
                                            <ToolTip>
                                                <StackPanel Margin="4">
                                                    <TextBlock Text="{Binding [Dashboard.PerfBreakdown], Source={x:Static services:LocalizationService.Instance}}" FontWeight="Bold" Margin="0,0,0,4"/>
                                                    
                                                    <!-- Warning for Missing Hook Data -->
                                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,8" 
                                                                Visibility="{Binding Status, Converter={StaticResource StatusToVisibilityConverter}, ConverterParameter=Fallback}">
                                                        <ui:SymbolIcon Symbol="Warning24" Margin="0,0,8,0">
                                                            <ui:SymbolIcon.Style>
                                                                <Style TargetType="ui:SymbolIcon">
                                                                    <Setter Property="Foreground" Value="#FFC107"/> <!-- Default Yellow -->
                                                                    <Style.Triggers>
                                                                        <DataTrigger Binding="{Binding Status}" Value="Orphaned / Missing DLL">
                                                                            <Setter Property="Foreground" Value="{DynamicResource SystemFillColorCriticalBrush}"/>
                                                                        </DataTrigger>
                                                                        <DataTrigger Binding="{Binding Status}" Value="Load Error">
                                                                            <Setter Property="Foreground" Value="{DynamicResource SystemFillColorCriticalBrush}"/>
                                                                        </DataTrigger>
                                                                    </Style.Triggers>
                                                                </Style>
                                                            </ui:SymbolIcon.Style>
                                                        </ui:SymbolIcon>
                                                        <TextBlock Text="{Binding [Dashboard.PerfEstimated], Source={x:Static services:LocalizationService.Instance}}" FontSize="11" VerticalAlignment="Center">
                                                            <TextBlock.Style>
                                                                <Style TargetType="TextBlock">
                                                                    <Setter Property="Foreground" Value="#FFC107"/>
                                                                    <Style.Triggers>
                                                                        <DataTrigger Binding="{Binding Status}" Value="Orphaned / Missing DLL">
                                                                            <Setter Property="Foreground" Value="{DynamicResource SystemFillColorCriticalBrush}"/>
                                                                        </DataTrigger>
                                                                        <DataTrigger Binding="{Binding Status}" Value="Load Error">
                                                                            <Setter Property="Foreground" Value="{DynamicResource SystemFillColorCriticalBrush}"/>
                                                                        </DataTrigger>
                                                                    </Style.Triggers>
                                                                </Style>
                                                            </TextBlock.Style>
                                                        </TextBlock>
                                                    </StackPanel>

                                                    <Grid>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="Auto"/>
                                                            <ColumnDefinition Width="Auto"/>
                                                        </Grid.ColumnDefinitions>
                                                        <Grid.RowDefinitions>
                                                            <RowDefinition Height="Auto"/>
                                                            <RowDefinition Height="Auto"/>
                                                            <RowDefinition Height="Auto"/>
                                                            <RowDefinition Height="Auto"/>
                                                            <RowDefinition Height="Auto"/>
                                                            <RowDefinition Height="Auto"/>
                                                            <RowDefinition Height="Auto"/>
                                                            <RowDefinition Height="Auto"/>
                                                            <RowDefinition Height="Auto"/>
                                                            <RowDefinition Height="Auto"/>
                                                            <RowDefinition Height="Auto"/>
                                                        </Grid.RowDefinitions>
                                                        
                                                        <TextBlock Grid.Row="0" Grid.Column="0" Text="{Binding [Dashboard.Create], Source={x:Static services:LocalizationService.Instance}}" Margin="0,0,12,2"/>
                                                        <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding CreateTime, StringFormat='{}{0:F2} ms'}" HorizontalAlignment="Right"/>
                                                        
                                                        <TextBlock Grid.Row="1" Grid.Column="0" Text="{Binding [Dashboard.Initialize], Source={x:Static services:LocalizationService.Instance}}" Margin="0,0,12,2"/>
                                                        <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding InitTime, StringFormat='{}{0:F2} ms'}" HorizontalAlignment="Right"/>
                                                        
                                                        <TextBlock Grid.Row="2" Grid.Column="0" Text="{Binding [Dashboard.Query], Source={x:Static services:LocalizationService.Instance}}" Margin="0,0,12,2"/>
                                                        <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding QueryTime, StringFormat='{}{0:F2} ms'}" HorizontalAlignment="Right"/>
                                                        
                                                        <TextBlock Grid.Row="3" Grid.Column="0" Text="{Binding [Dashboard.WallClock], Source={x:Static services:LocalizationService.Instance}}" Margin="0,0,12,2"/>
                                                        <TextBlock Grid.Row="3" Grid.Column="1" Text="{Binding WallClockTime, StringFormat='{}{0} ms'}" HorizontalAlignment="Right"/>
                                                        
                                                        <Separator Grid.Row="4" Grid.ColumnSpan="2" Margin="0,4"/>
                                                        <TextBlock Grid.Row="5" Grid.Column="0" Text="{Binding [Dashboard.Total], Source={x:Static services:LocalizationService.Instance}}" FontWeight="SemiBold"/>
                                                        <TextBlock Grid.Row="5" Grid.Column="1" FontWeight="SemiBold" HorizontalAlignment="Right">
                                                            <TextBlock.Text>
                                                                <MultiBinding Converter="{StaticResource LoadTimeToTextConverter}">
                                                                    <Binding Path="TotalTime"/>
                                                                    <Binding Path="Status"/>
                                                                </MultiBinding>
                                                            </TextBlock.Text>
                                                        </TextBlock>
                                                        
                                                        <Separator Grid.Row="6" Grid.ColumnSpan="2" Margin="0,8,0,6" Opacity="0.45"/>
                                                        <TextBlock Grid.Row="7" Grid.Column="0" Grid.ColumnSpan="2" Text="{Binding [Dashboard.Diagnostics], Source={x:Static services:LocalizationService.Instance}}" FontSize="11" FontWeight="SemiBold" Foreground="{DynamicResource TextFillColorSecondaryBrush}" Margin="0,0,0,2"/>
                                                        
                                                        <TextBlock Grid.Row="8" Grid.Column="0" Text="{Binding [Dashboard.LockWait], Source={x:Static services:LocalizationService.Instance}}" Margin="0,0,12,1" FontSize="11" Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                                                        <TextBlock Grid.Row="8" Grid.Column="1" Text="{Binding LockWaitTime, StringFormat='{}{0} ms'}" HorizontalAlignment="Right" FontSize="11" Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                                                        
                                                        <TextBlock Grid.Row="9" Grid.Column="0" Text="{Binding [Dashboard.PipeConnect], Source={x:Static services:LocalizationService.Instance}}" Margin="0,0,12,1" FontSize="11" Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                                                        <TextBlock Grid.Row="9" Grid.Column="1" Text="{Binding ConnectTime, StringFormat='{}{0} ms'}" HorizontalAlignment="Right" FontSize="11" Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                                                        
                                                        <TextBlock Grid.Row="10" Grid.Column="0" Text="{Binding [Dashboard.IpcRoundTrip], Source={x:Static services:LocalizationService.Instance}}" Margin="0,0,12,0" FontSize="11" Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                                                        <TextBlock Grid.Row="10" Grid.Column="1" Text="{Binding IpcRoundTripTime, StringFormat='{}{0} ms'}" HorizontalAlignment="Right" FontSize="11" Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                                                    </Grid>
                                                </StackPanel>
                                            </ToolTip>
                                        </Border.ToolTip>
                                        <TextBlock FontSize="11" FontWeight="SemiBold" Foreground="{Binding TotalTime, Converter={StaticResource LoadTimeToBrushConverter}}">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding Status}" Value="Registry Fallback">
                                                            <Setter Property="Foreground" Value="#FFC107"/>
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding Status}" Value="Hook Loaded (No Menu)">
                                                            <Setter Property="Foreground" Value="#FFC107"/>
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding Status}" Value="Load Error">
                                                            <Setter Property="Foreground" Value="{DynamicResource SystemFillColorCriticalBrush}"/>
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding Status}" Value="Orphaned / Missing DLL">
                                                            <Setter Property="Foreground" Value="{DynamicResource SystemFillColorCriticalBrush}"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                            <TextBlock.Text>
                                                <MultiBinding Converter="{StaticResource LoadTimeToTextConverter}">
                                                    <Binding Path="TotalTime"/>
                                                    <Binding Path="Status"/>
                                                </MultiBinding>
                                            </TextBlock.Text>
                                        </TextBlock>
                                    </Border>

                                    <!-- Toggle -->
                                    <ui:ToggleSwitch Grid.Column="3" IsChecked="{Binding IsEnabled, Mode=TwoWay}" 
                                                     VerticalAlignment="Center"
                                                     Command="{Binding DataContext.ToggleExtensionCommand, RelativeSource={RelativeSource AncestorType=Page}}" 
                                                     CommandParameter="{Binding}" Margin="0,0,8,0"/>
                                    
                                    <!-- Spacer for arrow -->
                                    <Border Grid.Column="4" Width="32"/>
                                </Grid>
                            </Expander.Header>

                            <!-- Expanded Content -->
                            <StackPanel Margin="48,8,0,0">
                                <Separator Margin="0,0,0,16" Opacity="0.3"/>
                                
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>

                                    <!-- CLSID -->
                                    <TextBlock Grid.Row="0" Grid.Column="0" Text="{Binding [Dashboard.Label.Clsid], Source={x:Static services:LocalizationService.Instance}}" FontWeight="SemiBold" Margin="0,0,16,8" VerticalAlignment="Center"
                                               Visibility="{Binding Clsid, Converter={StaticResource StringNullOrEmptyToVisibilityConverter}, ConverterParameter=Inverse}"/>
                                    <StackPanel Grid.Row="0" Grid.Column="1" Orientation="Horizontal" Margin="0,0,0,8"
                                                Visibility="{Binding Clsid, Converter={StaticResource StringNullOrEmptyToVisibilityConverter}, ConverterParameter=Inverse}">
                                        <TextBlock Text="{Binding Clsid, StringFormat='{}{0:B}'}" VerticalAlignment="Center" FontFamily="Consolas"/>
                                        <ui:Button Content="{Binding [Dashboard.Action.Copy], Source={x:Static services:LocalizationService.Instance}}" Icon="{ui:SymbolIcon Symbol=Copy24}" Margin="12,0,0,0" Padding="8,2"
                                                   Command="{Binding DataContext.CopyClsidCommand, RelativeSource={RelativeSource AncestorType=Page}}"
                                                   CommandParameter="{Binding}"/>
                                    </StackPanel>

                                    <!-- Binary Path -->
                                    <TextBlock Grid.Row="1" Grid.Column="0" Text="{Binding [Dashboard.Label.Binary], Source={x:Static services:LocalizationService.Instance}}" FontWeight="SemiBold" Margin="0,0,16,8" VerticalAlignment="Top"/>
                                    <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding BinaryPath}" TextWrapping="Wrap" Margin="0,0,0,8" Opacity="0.8" FontFamily="Consolas" FontSize="12"/>

                                    <!-- Details -->
                                    <TextBlock Grid.Row="2" Grid.Column="0" Text="{Binding [Dashboard.Label.Details], Source={x:Static services:LocalizationService.Instance}}" FontWeight="SemiBold" Margin="0,0,16,8" VerticalAlignment="Top"/>
                                    <WrapPanel Grid.Row="2" Grid.Column="1" Margin="0,0,0,8">
                                        <StackPanel Orientation="Horizontal" Margin="0,0,16,4">
                                            <TextBlock Text="{Binding [Dashboard.Label.Interface], Source={x:Static services:LocalizationService.Instance}}" Opacity="0.6"/>
                                            <TextBlock Text="{Binding InterfaceType, Converter={StaticResource NullOrEmptyToLocalizedConverter}, ConverterParameter=Dashboard.Value.Unknown}" FontWeight="Medium"/>
                                        </StackPanel>
                                        
                                        <StackPanel Orientation="Horizontal" Margin="0,0,16,4">
                                            <TextBlock Text="{Binding [Dashboard.Label.IconSource], Source={x:Static services:LocalizationService.Instance}}" Opacity="0.6"/>
                                            <TextBlock Text="{Binding IconSource, Converter={StaticResource NullOrEmptyToLocalizedConverter}, ConverterParameter=Dashboard.Value.None}" FontWeight="Medium"/>
                                        </StackPanel>
                                        
                                        <StackPanel Orientation="Horizontal" Margin="0,0,16,4" 
                                                   Visibility="{Binding ThreadingModel, Converter={StaticResource StringNullOrEmptyToVisibilityConverter}, ConverterParameter=Inverse}">
                                            <TextBlock Text="{Binding [Dashboard.Label.Threading], Source={x:Static services:LocalizationService.Instance}}" Opacity="0.6"/>
                                            <TextBlock Text="{Binding ThreadingModel}" FontWeight="Medium"/>
                                        </StackPanel>

                                        <StackPanel Orientation="Horizontal" Margin="0,0,16,4" 
                                                   Visibility="{Binding FriendlyName, Converter={StaticResource StringNullOrEmptyToVisibilityConverter}, ConverterParameter=Inverse}">
                                            <TextBlock Text="{Binding [Dashboard.Label.RegistryName], Source={x:Static services:LocalizationService.Instance}}" Opacity="0.6"/>
                                            <TextBlock Text="{Binding FriendlyName}" FontWeight="Medium"/>
                                        </StackPanel>
                                    </WrapPanel>

                                    <!-- Registry Locations -->
                                    <TextBlock Grid.Row="3" Grid.Column="0" Text="{Binding [Dashboard.Label.Registry], Source={x:Static services:LocalizationService.Instance}}" FontWeight="SemiBold" Margin="0,0,16,8" VerticalAlignment="Top"/>
                                    <ItemsControl Grid.Row="3" Grid.Column="1" ItemsSource="{Binding RegistryEntries}" Margin="0,0,0,8">
                                        <ItemsControl.ItemsPanel>
                                            <ItemsPanelTemplate>
                                                <WrapPanel/>
                                            </ItemsPanelTemplate>
                                        </ItemsControl.ItemsPanel>
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <ui:Button Appearance="Secondary" Margin="0,0,8,8" Padding="10,4"
                                                           Command="{Binding DataContext.OpenInRegistryCommand, RelativeSource={RelativeSource AncestorType=Page}}"
                                                           CommandParameter="{Binding Path}"
                                                           ToolTip="{Binding Path}">
                                                    <StackPanel Orientation="Horizontal">
                                                        <ui:SymbolIcon Symbol="Open24" Margin="0,0,6,0" FontSize="14"/>
                                                        <TextBlock Text="{Binding Location}" FontSize="11"/>
                                                    </StackPanel>
                                                </ui:Button>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>

                                    <!-- Package Info (UWP only) -->
                                    <TextBlock Grid.Row="4" Grid.Column="0" Text="{Binding [Dashboard.Label.Package], Source={x:Static services:LocalizationService.Instance}}" FontWeight="SemiBold" Margin="0,0,16,8" 
                                               Visibility="{Binding PackageName, Converter={StaticResource StringNullOrEmptyToVisibilityConverter}, ConverterParameter=Inverse}"/>
                                    <StackPanel Grid.Row="4" Grid.Column="1" Orientation="Horizontal"
                                                Visibility="{Binding PackageName, Converter={StaticResource StringNullOrEmptyToVisibilityConverter}, ConverterParameter=Inverse}">
                                        <TextBlock Text="{Binding PackageName}" Margin="0,0,8,8"/>
                                        <TextBlock Text="{Binding Version, StringFormat='(v{0})'}" Opacity="0.6"/>
                                    </StackPanel>
                                </Grid>

                                <!-- Actions -->
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,16,0,0">
                                    <ui:Button Content="{Binding [Dashboard.Action.DeletePermanently], Source={x:Static services:LocalizationService.Instance}}" Appearance="Danger" Icon="{ui:SymbolIcon Symbol=Delete24}"
                                               Command="{Binding DataContext.DeleteExtensionCommand, RelativeSource={RelativeSource AncestorType=Page}}"
                                               CommandParameter="{Binding}"
                                               Visibility="{Binding Type, Converter={StaticResource StatusToVisibilityConverter}, ConverterParameter=NotUWP}"/>
                                </StackPanel>
                            </StackPanel>
                        </Expander>
                    </ui:Card>
                </DataTemplate>
            </ui:ListView.ItemTemplate>
        </ui:ListView>
        
    </Grid>
</Page>
